# ============================================
# App Horarios - Environment Variables
# ============================================
# Supabase Cloud - get these from: https://supabase.com/dashboard > Settings > API

NEXT_PUBLIC_SUPABASE_URL=https://YOUR_PROJECT_ID.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=YOUR_ANON_KEY
SUPABASE_SERVICE_ROLE_KEY=YOUR_SERVICE_ROLE_KEY

# Public URL del frontend (para redirectTo en correos de invitación / reset de password).
# Producción: https://app-horarios-mauve.vercel.app
# Desarrollo local: http://localhost:3000
NEXT_PUBLIC_APP_URL=https://app-horarios-mauve.vercel.app
