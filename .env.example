# ============================================
# App Horarios - Environment Variables
# ============================================
# Supabase Cloud - get these from: https://supabase.com/dashboard > Settings > API

NEXT_PUBLIC_SUPABASE_URL=https://YOUR_PROJECT_ID.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=YOUR_ANON_KEY
SUPABASE_SERVICE_ROLE_KEY=YOUR_SERVICE_ROLE_KEY

# Public URL del frontend (para redirectTo en correos de invitación / reset de password).
# Producción: https://app-horarios-mauve.vercel.app
# Desarrollo local: http://localhost:3000
NEXT_PUBLIC_APP_URL=https://app-horarios-mauve.vercel.app
# Sitio público (preferido sobre NEXT_PUBLIC_APP_URL para invitaciones — apunta al dominio del cliente).
# Sub-proy 3: default a tushorarios.com para invitaciones SaaS.
NEXT_PUBLIC_SITE_URL=https://www.tushorarios.com

# ============================================
# Resend - transactional email (sub-proyecto 1)
# ============================================
# Get API key from: https://resend.com/api-keys
# Dominio verificado: tushorarios.com (sub-proyecto 1 design doc)

RESEND_API_KEY=
RESEND_FROM_NOREPLY=noreply@tushorarios.com
RESEND_FROM_HOLA=hola@tushorarios.com
RESEND_FROM_NOTIF=notificaciones@tushorarios.com

# ============================================
# Subdomain routing (sub-proyecto 5)
# ============================================
# Root domain en producción. Determina el scope de cookies (.tushorarios.com)
# y el comportamiento del middleware al extraer subdomains.
# - Producción: tushorarios.com
# - Local dev: lvh.me (acceder via acme.lvh.me:3000)
NEXT_PUBLIC_ROOT_DOMAIN=tushorarios.com

# ============================================
# Wompi - billing (sub-proyecto 6)
# ============================================
# Obtener en https://comercios.wompi.co/developers
# Modo Sandbox: prefijos pub_test_, prv_test_, test_integrity_, test_events_
# Modo Producción: prefijos pub_prod_, prv_prod_, prod_integrity_, prod_events_
NEXT_PUBLIC_WOMPI_PUBLIC_KEY=
WOMPI_PRIVATE_KEY=
WOMPI_INTEGRITY_SECRET=
WOMPI_EVENTS_SECRET=

# AES-256-GCM key (32 bytes base64) para cifrar credenciales DIAN en billing_providers.
# Generar con: node -e "console.log(require('crypto').randomBytes(32).toString('base64'))"
BILLING_CREDS_ENC_KEY=

# Auth Bearer token para los endpoints de cron de billing (Vercel Cron).
# Generar con: openssl rand -hex 32
CRON_SECRET=

# Feature flag billing (sub-proyecto 6). Soft launch: false en prod inicialmente.
# Deben tener el MISMO valor. NEXT_PUBLIC_ es client-side; BILLING_ENABLED es server-side (middleware R10).
NEXT_PUBLIC_BILLING_ENABLED=false
BILLING_ENABLED=false
